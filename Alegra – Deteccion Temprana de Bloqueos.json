    {
      "parameters": {
        "jsCode": "const agentOutput = JSON.parse($node[\"AI Agent\"].json.output);\nconst tareasRiesgo = agentOutput.tareas_en_riesgo || [];\n\nconst filasOriginales = $(\"Calcular metricas y semaforo\").all();\n\nreturn filasOriginales.map(item => {\n  const r = item.json;\n  const encontrada = tareasRiesgo.find(t => t.id === r.id);\n  return {\n    json: {\n      id: r.id,\n      semaforo: encontrada ? encontrada.semaforo : r.semaforo\n    }\n  };\n});"
      },
