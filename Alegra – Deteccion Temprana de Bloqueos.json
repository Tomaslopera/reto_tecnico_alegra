    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst content = raw.output;\nconst analisis = JSON.parse(content);\n\nconst detalle = analisis.detalle_alerta || {};\nconst diasImpacto = parseInt(detalle.dias_impacto_estimado || 0);\nconst tareaOrigen = String(detalle.tarea_origen || \"T1\");\n\nconst ruta = [\n  { id: \"T1\",  fin: 10 },\n  { id: \"I\",   fin: 20 },\n  { id: \"II\",  fin: 22 },\n  { id: \"III\", fin: 27 },\n  { id: \"V\",   fin: 30 }\n];\n\nconst cadena = [];\nlet aplicar = false;\n\nfor (const t of ruta) {\n  if (t.id === tareaOrigen) aplicar = true;\n  if (aplicar) {\n    cadena.push({\n      id:             t.id,\n      fin_original:   t.fin,\n      fin_proyectado: t.fin + diasImpacto,\n      dias_retraso:   diasImpacto\n    });\n  }\n}\n\nconst entrega = cadena.length > 0 ? cadena[cadena.length - 1].fin_proyectado : 30;\n\nreturn [{\n  json: {\n    analisis_completo:  analisis,\n    cadena_impacto:     cadena,\n    dias_retraso_total: diasImpacto,\n    entrega_proyectada: entrega,\n    entrega_en_riesgo:  entrega > 30,\n    tarea_origen:       tareaOrigen,\n    accion_inmediata:   detalle.accion_inmediata || \"\"\n  }\n}];"
      },
