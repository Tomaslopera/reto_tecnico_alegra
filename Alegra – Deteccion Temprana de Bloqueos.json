    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\nconst cadenaHtml = (d.cadena_impacto || []).map((t, i) =>\n  `<tr style=\"background:${i % 2 === 0 ? '#ffffff' : '#F9FAFB'}\">\n    <td style=\"padding:12px 16px;font-weight:600;color:#1A1A2E;border-bottom:1px solid #EEF0F3\">${t.id}</td>\n    <td style=\"padding:12px 16px;color:#6B7280;border-bottom:1px solid #EEF0F3\">Día ${t.fin_original}</td>\n    <td style=\"padding:12px 16px;border-bottom:1px solid #EEF0F3\">\n      <span style=\"background:#FEE2E2;color:#DC2626;font-weight:700;padding:3px 10px;border-radius:20px;font-size:12px\">Día ${t.fin_proyectado} +${t.dias_retraso}d</span>\n    </td>\n  </tr>`\n).join('');\n\nconst html = `<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#F0FAF8;font-family:'Helvetica Neue',Arial,sans-serif\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:40px 0\">\n<tr><td align=\"center\">\n<table width=\"580\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,193,162,0.10)\">\n  <tr>\n    <td style=\"padding:24px 32px;border-bottom:3px solid #00C1A2\">\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n        <td><span style=\"color:#00C1A2;font-size:20px;font-weight:800;letter-spacing:-0.5px\">alegra</span><span style=\"color:#9CA3AF;font-size:13px;margin-left:10px\">· Sistema de Detección Temprana</span></td>\n        <td align=\"right\"><span style=\"background:#FEE2E2;color:#DC2626;font-size:11px;font-weight:700;padding:5px 12px;border-radius:20px;letter-spacing:0.8px\">ALERTA CRITICA</span></td>\n      </tr></table>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"background:#DC2626;padding:20px 32px\">\n      <p style=\"margin:0;color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;opacity:0.85\">Detección Temprana de Bloqueos</p>\n      <p style=\"margin:6px 0 0;color:#fff;font-size:18px;font-weight:700\">Ruta Crítica en Riesgo — Acción inmediata requerida</p>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"padding:28px 32px 0\">\n      <p style=\"margin:0 0 4px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Origen del bloqueo</p>\n      <p style=\"margin:0;font-size:28px;font-weight:800;color:#1A1A2E\">Tarea ${d.tarea_origen}</p>\n      <p style=\"margin:12px 0 0;font-size:14px;line-height:1.8;color:#4B5563\">${d.analisis_completo?.detalle_alerta?.descripcion || ''}</p>\n    </td>\n  </tr>\n  <tr><td style=\"padding:24px 32px 0\"><div style=\"height:1px;background:#EEF0F3\"></div></td></tr>\n  <tr>\n    <td style=\"padding:24px 32px 0\">\n      <p style=\"margin:0 0 14px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Impacto en cadena proyectado</p>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse;border:1px solid #EEF0F3;border-radius:10px;overflow:hidden\">\n        <tr style=\"background:#F9FAFB\">\n          <th style=\"padding:10px 16px;text-align:left;font-size:11px;font-weight:700;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">TAREA</th>\n          <th style=\"padding:10px 16px;text-align:left;font-size:11px;font-weight:700;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">FIN ORIGINAL</th>\n          <th style=\"padding:10px 16px;text-align:left;font-size:11px;font-weight:700;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">FIN PROYECTADO</th>\n        </tr>\n        ${cadenaHtml}\n      </table>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"padding:24px 32px 0\">\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FFFBEB;border:1px solid #FDE68A;border-radius:10px\">\n        <tr><td style=\"padding:14px 20px 4px\"><p style=\"margin:0;font-size:10px;font-weight:700;color:#D97706;letter-spacing:2px;text-transform:uppercase\">Acción inmediata requerida</p></td></tr>\n        <tr><td style=\"padding:0 20px 16px\"><p style=\"margin:0;font-size:14px;line-height:1.8;color:#1A1A2E\">${d.accion_inmediata}</p></td></tr>\n      </table>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"padding:24px 32px 32px\">\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n        <td><p style=\"margin:0;font-size:12px;color:#9CA3AF\">Entrega proyectada: <strong style=\"color:#DC2626\">Día ${d.entrega_proyectada}</strong> · Compromiso: Día 30</p><p style=\"margin:4px 0 0;font-size:11px;color:#D1D5DB\">Generado automáticamente · Alegra</p></td>\n        <td align=\"right\" style=\"vertical-align:bottom\"><span style=\"color:#00C1A2;font-size:14px;font-weight:800\">alegra</span></td>\n      </tr></table>\n    </td>\n  </tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>`;\n\nreturn [{ json: { email_html: html, tarea_origen: d.tarea_origen, entrega_proyectada: d.entrega_proyectada } }];"
