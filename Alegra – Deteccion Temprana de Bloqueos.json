    {
      "parameters": {
        "jsCode": "const WEBHOOK_DATA = $('Webhook').first().json.query;\nconst TAB = WEBHOOK_DATA.tab || 'Dia5';\nconst DIA_MAP = { 'Dia5': 5, 'Dia10': 10, 'Dia15': 15, 'Dia20': 20 };\nconst DIA_ACTUAL = DIA_MAP[TAB] || 5;\n\nconst items = $input.all();\n\nfunction parsePct(val) {\n  try { return parseFloat(String(val).replace('%', '').trim()) / 100; }\n  catch { return 0; }\n}\nfunction parseDia(s) {\n  try { return parseInt(String(s).replace(/D[ií]a /i, '').trim()); }\n  catch { return 1; }\n}\nfunction avanceEsperado(inicio, fin, actual) {\n  if (actual < inicio) return 0;\n  if (actual >= fin) return 1;\n  return Math.round(((actual - inicio) / (fin - inicio)) * 10000) / 10000;\n}\nfunction calcSemaforo(avReal, avEsp, diasSin, enCritica, estado) {\n  const e = String(estado);\n  if (e.includes('Completada')) return 'VERDE';\n  if (e.includes('No iniciada') && avEsp === 0) return 'GRIS';\n  if (e.includes('Bloqueada') || e.includes('SIN ASIGNAR')) return 'ROJO';\n  const brecha = avEsp - avReal;\n  const dias = parseInt(diasSin || 0);\n  if (enCritica) {\n    if (brecha > 0.15 || dias > 2) return 'ROJO';\n    if (brecha > 0.05 || dias > 1) return 'AMARILLO';\n    return 'VERDE';\n  } else {\n    if (brecha > 0.20 || dias > 3) return 'ROJO';\n    if (brecha > 0.10 || dias > 2) return 'AMARILLO';\n    return 'VERDE';\n  }\n}\nfunction calcScore(avReal, avEsp, diasSin, enCritica, sem) {\n  let score = Math.min((avEsp - avReal) * 200, 50) + Math.min(parseInt(diasSin || 0) * 8, 20);\n  if (enCritica) score *= 1.5;\n  if (sem === 'ROJO') score += 20;\n  else if (sem === 'AMARILLO') score += 10;\n  return Math.round(Math.min(score, 100) * 10) / 10;\n}\n\nreturn items.map(item => {\n  const r = item.json;\n  const enCritica = String(r.en_ruta_critica || 'NO').trim().toUpperCase() === 'SI';\n  const avReal = parsePct(r.ultimo_avance || '0%');\n  const diasSin = r.dias_sin_avance || 0;\n  const estado = String(r.estado_actual || '');\n  const inicio = parseDia(r.fecha_inicio || 'Dia 1');\n  const fin = parseDia(r.fecha_limite || 'Dia 30');\n  const avEsp = avanceEsperado(inicio, fin, DIA_ACTUAL);\n  const brechaDias = Math.round((avEsp - avReal) * Math.max(fin - inicio, 1) * 10) / 10;\n  const sem = calcSemaforo(avReal, avEsp, diasSin, enCritica, estado);\n  const score = calcScore(avReal, avEsp, diasSin, enCritica, sem);\n  return {\n    json: {\n      ...r,\n      avance_real_num:      avReal,\n      avance_esperado_num:  avEsp,\n      brecha_pct:           Math.round((avEsp - avReal) * 10000) / 10000,\n      brecha_dias_estimada: brechaDias,\n      semaforo:             sem,\n      en_ruta_critica_bool: enCritica,\n      riesgo_score:         score,\n      dia_calculo:          DIA_ACTUAL\n    }\n  };\n});"
      },
