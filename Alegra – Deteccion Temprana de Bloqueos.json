      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const raw = $node[\"AI Agent\"].json.output;\nconst a = JSON.parse(raw);\n\nconst colorMap = { VERDE: '#00C1A2', AMARILLO: '#F5A623', ROJO: '#DC2626' };\nconst c = colorMap[a.semaforo_general] || '#9CA3AF';\n\nconst tareasHtml = (a.tareas_en_riesgo || []).map(t =>\n  `<tr>\n    <td style=\"padding:12px 16px;font-weight:600;color:#1A1A2E;border-bottom:1px solid #EEF0F3\">${t.id}</td>\n    <td style=\"padding:12px 16px;border-bottom:1px solid #EEF0F3\">\n      <span style=\"background:${t.semaforo === 'ROJO' ? '#FEE2E2' : '#FEF3C7'};color:${t.semaforo === 'ROJO' ? '#DC2626' : '#D97706'};font-weight:700;padding:3px 10px;border-radius:20px;font-size:12px\">${t.semaforo}</span>\n    </td>\n    <td style=\"padding:12px 16px;font-size:13px;color:#4B5563;border-bottom:1px solid #EEF0F3\">${t.diagnostico}</td>\n  </tr>`\n).join('');\n\nconst html = `<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#F0FAF8;font-family:'Helvetica Neue',Arial,sans-serif\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:40px 0\">\n<tr><td align=\"center\">\n<table width=\"580\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,193,162,0.10)\">\n  <tr>\n    <td style=\"padding:24px 32px;border-bottom:3px solid #00C1A2\">\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n        <td><span style=\"color:#00C1A2;font-size:20px;font-weight:800\">alegra</span><span style=\"color:#9CA3AF;font-size:13px;margin-left:10px\">· Reporte de Salud del Proyecto</span></td>\n        <td align=\"right\"><span style=\"background:${c};color:#fff;font-size:11px;font-weight:700;padding:5px 12px;border-radius:20px\">${a.semaforo_general}</span></td>\n      </tr></table>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"background:#F8FFFE;padding:24px 32px;border-bottom:1px solid #EEF0F3\">\n      <p style=\"margin:0 0 4px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Diagnóstico ejecutivo</p>\n      <p style=\"margin:0;font-size:15px;line-height:1.8;color:#1A1A2E\">${a.resumen_ejecutivo}</p>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"padding:24px 32px 0\">\n      <p style=\"margin:0 0 14px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Estado por equipo</p>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #EEF0F3;border-radius:10px;overflow:hidden\">\n        <tr style=\"background:#F9FAFB\"><td style=\"padding:12px 16px;font-weight:700;font-size:13px;color:#1A1A2E;border-bottom:1px solid #EEF0F3;width:100px\">Marketing</td><td style=\"padding:12px 16px;font-size:13px;color:#4B5563;border-bottom:1px solid #EEF0F3\">${a.estado_por_equipo?.Marketing || ''}</td></tr>\n        <tr><td style=\"padding:12px 16px;font-weight:700;font-size:13px;color:#1A1A2E;border-bottom:1px solid #EEF0F3\">Ventas</td><td style=\"padding:12px 16px;font-size:13px;color:#4B5563;border-bottom:1px solid #EEF0F3\">${a.estado_por_equipo?.Ventas || ''}</td></tr>\n        <tr style=\"background:#F9FAFB\"><td style=\"padding:12px 16px;font-weight:700;font-size:13px;color:#1A1A2E\">Producto</td><td style=\"padding:12px 16px;font-size:13px;color:#4B5563\">${a.estado_por_equipo?.Producto || ''}</td></tr>\n      </table>\n    </td>\n  </tr>\n  ${tareasHtml.length ? `\n  <tr>\n    <td style=\"padding:24px 32px 0\">\n      <p style=\"margin:0 0 14px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Tareas que requieren atención</p>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #EEF0F3;border-radius:10px;overflow:hidden\">\n        <tr style=\"background:#F9FAFB\">\n          <th style=\"padding:10px 16px;text-align:left;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">TAREA</th>\n          <th style=\"padding:10px 16px;text-align:left;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">ESTADO</th>\n          <th style=\"padding:10px 16px;text-align:left;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">DIAGNÓSTICO</th>\n        </tr>\n        ${tareasHtml}\n      </table>\n    </td>\n  </tr>` : ''}\n  <tr>\n    <td style=\"padding:24px 32px 0\">\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#F0FAF8;border:1px solid #00C1A2;border-radius:10px\">\n        <tr><td style=\"padding:14px 20px 4px\"><p style=\"margin:0;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Impacto estimado en entrega</p></td></tr>\n        <tr><td style=\"padding:0 20px 16px\"><p style=\"margin:0;font-size:14px;color:#1A1A2E\">${a.impacto_fecha_entrega}</p></td></tr>\n      </table>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"padding:24px 32px 32px\">\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n        <td><p style=\"margin:0;font-size:11px;color:#D1D5DB\">Generado automáticamente por el Sistema de Detección Temprana · Alegra</p></td>\n        <td align=\"right\"><span style=\"color:#00C1A2;font-size:14px;font-weight:800\">alegra</span></td>\n      </tr></table>\n    </td>\n  </tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>`;\n\nreturn [{ json: { email_html: html, semaforo_general: a.semaforo_general } }];"
