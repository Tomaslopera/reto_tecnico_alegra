    {
      "parameters": {
        "jsCode": "const a = JSON.parse($node[\"AI Agent\"].json.output);\n\nconst nivelColor = { ALTO: '#DC2626', MEDIO: '#F5A623', BAJO: '#00C1A2' };\nconst nivelBg   = { ALTO: '#FEE2E2', MEDIO: '#FEF3C7', BAJO: '#F0FAF8' };\n\nconst riesgosHtml = (a.riesgos_identificados || []).map(r =>\n  `<tr>\n    <td style=\"padding:12px 16px;font-size:13px;color:#1A1A2E;border-bottom:1px solid #EEF0F3\">${r.descripcion}</td>\n    <td style=\"padding:12px 16px;border-bottom:1px solid #EEF0F3;text-align:center\">\n      ${r.tarea_afectada ? `<span style=\"background:#EEF0F3;color:#1A1A2E;font-weight:700;padding:2px 8px;border-radius:12px;font-size:12px\">${r.tarea_afectada}</span>` : '—'}\n    </td>\n    <td style=\"padding:12px 16px;border-bottom:1px solid #EEF0F3;text-align:center\">\n      <span style=\"background:${nivelBg[r.nivel]||'#EEF0F3'};color:${nivelColor[r.nivel]||'#888'};font-weight:700;padding:3px 10px;border-radius:20px;font-size:12px\">${r.nivel}</span>\n    </td>\n  </tr>`\n).join('');\n\nconst acuerdosHtml = (a.acuerdos || []).map(ac =>\n  `<tr>\n    <td style=\"padding:12px 16px;font-size:13px;color:#1A1A2E;border-bottom:1px solid #EEF0F3\">${ac.descripcion}</td>\n    <td style=\"padding:12px 16px;font-size:13px;font-weight:600;color:#4B5563;border-bottom:1px solid #EEF0F3\">${ac.responsable}</td>\n    <td style=\"padding:12px 16px;font-size:13px;font-weight:600;color:#00C1A2;border-bottom:1px solid #EEF0F3\">${ac.fecha_compromiso}</td>\n  </tr>`\n).join('');\n\nconst alertaBanner = a.alerta_ruta_critica ? `\n  <tr><td style=\"background:#FEE2E2;padding:14px 32px;border-left:4px solid #DC2626\">\n    <p style=\"margin:0;font-size:13px;color:#DC2626;font-weight:700\">Ruta crítica en riesgo — Requiere atención inmediata</p>\n  </td></tr>` : '';\n\nconst html = `<!DOCTYPE html>\n<html><body style=\"margin:0;padding:0;background:#F0FAF8;font-family:'Helvetica Neue',Arial,sans-serif\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:40px 0\">\n<tr><td align=\"center\">\n<table width=\"580\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,193,162,0.10)\">\n  <tr><td style=\"padding:24px 32px;border-bottom:3px solid #00C1A2\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n      <td><span style=\"color:#00C1A2;font-size:20px;font-weight:800\">alegra</span><span style=\"color:#9CA3AF;font-size:13px;margin-left:10px\">· Resumen de Reunión</span></td>\n      <td align=\"right\"><span style=\"background:#F0FAF8;color:#00C1A2;font-size:11px;font-weight:700;padding:5px 12px;border-radius:20px;border:1px solid #00C1A2\">${a.fecha_reunion}</span></td>\n    </tr></table>\n  </td></tr>\n  ${alertaBanner}\n  <tr><td style=\"background:#F8FFFE;padding:24px 32px;border-bottom:1px solid #EEF0F3\">\n    <p style=\"margin:0 0 4px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Resumen ejecutivo</p>\n    <p style=\"margin:0;font-size:15px;line-height:1.8;color:#1A1A2E\">${a.resumen_ejecutivo}</p>\n  </td></tr>\n  <tr><td style=\"padding:24px 32px 0\">\n    <p style=\"margin:0 0 8px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Participantes</p>\n    <p style=\"margin:0;font-size:13px;color:#4B5563\">${(a.participantes||[]).join(' · ')}</p>\n  </td></tr>\n  <tr><td style=\"padding:24px 32px 0\">\n    <p style=\"margin:0 0 10px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Puntos clave</p>\n    <ul style=\"margin:0;padding-left:18px\">${(a.puntos_clave||[]).map(p => `<li style=\"font-size:13px;color:#4B5563;line-height:1.8;margin-bottom:4px\">${p}</li>`).join('')}</ul>\n  </td></tr>\n  ${riesgosHtml ? `<tr><td style=\"padding:24px 32px 0\">\n    <p style=\"margin:0 0 14px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Riesgos identificados</p>\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #EEF0F3;border-radius:10px;overflow:hidden\">\n      <tr style=\"background:#F9FAFB\">\n        <th style=\"padding:10px 16px;text-align:left;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">RIESGO</th>\n        <th style=\"padding:10px 16px;text-align:center;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">TAREA</th>\n        <th style=\"padding:10px 16px;text-align:center;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">NIVEL</th>\n      </tr>${riesgosHtml}\n    </table>\n  </td></tr>` : ''}\n  ${acuerdosHtml ? `<tr><td style=\"padding:24px 32px 0\">\n    <p style=\"margin:0 0 14px;font-size:10px;font-weight:700;color:#00C1A2;letter-spacing:2px;text-transform:uppercase\">Acuerdos y compromisos</p>\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #EEF0F3;border-radius:10px;overflow:hidden\">\n      <tr style=\"background:#F9FAFB\">\n        <th style=\"padding:10px 16px;text-align:left;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">ACUERDO</th>\n        <th style=\"padding:10px 16px;text-align:left;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">RESPONSABLE</th>\n        <th style=\"padding:10px 16px;text-align:left;font-size:11px;color:#9CA3AF;border-bottom:1px solid #EEF0F3\">FECHA</th>\n      </tr>${acuerdosHtml}\n    </table>\n  </td></tr>` : ''}\n  <tr><td style=\"padding:24px 32px 0\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FFFBEB;border:1px solid #FDE68A;border-radius:10px\">\n      <tr><td style=\"padding:14px 20px 4px\"><p style=\"margin:0;font-size:10px;font-weight:700;color:#D97706;letter-spacing:2px;text-transform:uppercase\">Recomendación inmediata</p></td></tr>\n      <tr><td style=\"padding:0 20px 16px\"><p style=\"margin:0;font-size:14px;line-height:1.8;color:#1A1A2E\">${a.recomendacion_inmediata}</p></td></tr>\n    </table>\n  </td></tr>\n  <tr><td style=\"padding:24px 32px 32px\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n      <td><p style=\"margin:0;font-size:11px;color:#D1D5DB\">Generado automáticamente por el Sistema de Detección Temprana · Alegra</p></td>\n      <td align=\"right\"><span style=\"color:#00C1A2;font-size:14px;font-weight:800\">alegra</span></td>\n    </tr></table>\n  </td></tr>\n</table>\n</td></tr></table>\n</body></html>`;\n\nreturn [{ json: { email_html: html, alerta_ruta_critica: a.alerta_ruta_critica, fecha_reunion: a.fecha_reunion } }];"
      },
